{
    "name": "zod",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/plugins/zod/src",
    "projectType": "library",
    "release": {
        "version": {
            "manifestRootsToUpdate": ["dist/{projectRoot}"],
            "currentVersionResolver": "git-tag",
            "fallbackCurrentVersionResolver": "disk"
        }
    },
    "tags": ["scope:plugin"],
    "targets": {
        "nx-release-publish": {
            "options": {
                "packageRoot": "dist/{projectRoot}"
            }
        },
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx tsup",
                "cwd": "packages/plugins/zod"
            },
            "outputs": ["{workspaceRoot}/dist/packages/plugins/zod"]
        },
        "typecheck": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx tsc -p {projectRoot}/tsconfig.lib.json --noEmit"
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx vitest run packages/plugins/zod",
                "cwd": "{workspaceRoot}"
            }
        }
    }
}
