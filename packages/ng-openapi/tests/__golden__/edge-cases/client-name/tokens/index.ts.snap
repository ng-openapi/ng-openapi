import { InjectionToken } from "@angular/core";
import { HttpInterceptorFn, HttpContextToken } from "@angular/common/http";

/**
 * Injection token for the PetsApi client base API path
 */
export const BASE_PATH_PETSAPI = new InjectionToken<string>('BASE_PATH_PETSAPI', {
    providedIn: 'root',
    factory: () => '/api', // Default fallback
});
/**
 * Injection token carrying the PetsApi client's scoped interceptor chain,
 * normalized to functional interceptors. Populated by the client's provide function.
 */
export const HTTP_INTERCEPTOR_FNS_PETSAPI = new InjectionToken<HttpInterceptorFn[]>('HTTP_INTERCEPTOR_FNS_PETSAPI', {
    providedIn: 'root',
    factory: () => [], // Default empty array
});
/**
 * HttpContext token to identify requests belonging to the PetsApi client
 */
export const CLIENT_CONTEXT_TOKEN_PETSAPI = new HttpContextToken<string>(() => 'PetsApi');
