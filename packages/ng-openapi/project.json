{
    "name": "ng-openapi",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/ng-openapi/src",
    "projectType": "library",
    "release": {
        "version": {
            "manifestRootsToUpdate": ["dist/{projectRoot}"],
            "currentVersionResolver": "git-tag",
            "fallbackCurrentVersionResolver": "disk"
        }
    },
    "tags": ["scope:core"],
    "targets": {
        "nx-release-publish": {
            "options": {
                "packageRoot": "dist/{projectRoot}"
            }
        },
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx tsup",
                "cwd": "packages/ng-openapi"
            },
            "outputs": ["{workspaceRoot}/dist/packages/ng-openapi"]
        },
        "typecheck": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx tsc -p {projectRoot}/tsconfig.lib.json --noEmit"
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx vitest run packages/ng-openapi",
                "cwd": "{workspaceRoot}"
            }
        }
    }
}
