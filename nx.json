{
    "extends": "nx/presets/npm.json",
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "main",
    "nxCloudId": "687430d7011c6a6c64494347",
    "namedInputs": {
        "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yml"],
        "default": ["{projectRoot}/**/*", "sharedGlobals"]
    },
    "targetDefaults": {
        "build": {
            "dependsOn": ["^build"],
            "cache": true,
            "inputs": ["default", "^default"]
        },
        "typecheck": {
            "cache": true,
            "inputs": ["default", "^default", "{workspaceRoot}/tsconfig.base.json"]
        },
        "lint": {
            "cache": true,
            "inputs": ["default", "^default", "{workspaceRoot}/eslint.config.mjs"]
        },
        "test": {
            // Cache + env inputs apply to local `nx test` runs only: CI runs
            // `npm run test:coverage` (plain vitest) for the aggregated
            // coverage report and bypasses this cache (see ci.yml).
            "cache": true,
            "inputs": [
                "default",
                "^default",
                "{workspaceRoot}/vitest.config.ts",
                { "env": "OPENAPI_SPEC_V2_URL" },
                { "env": "OPENAPI_SPEC_V3_URL" },
                { "env": "OPENAPI_SPEC_V3_1_URL" }
            ]
        }
    },
    "release": {
        "version": {
            "preVersionCommand": "npx nx run-many -t build"
        }
    },
    "plugins": [
        {
            "plugin": "@nx/eslint/plugin",
            "options": {
                "targetName": "lint"
            },
            "include": ["packages/**"]
        }
    ],
    "analytics": false
}
